# Telegram Mini App 需要 HTTPS。下面给出反向代理 webapp_server.py 的示例。
# 先用 certbot 等申请好证书, 再把 server_name / 证书路径换成你自己的。
#
#   sudo cp deploy/nginx-webapp.conf.example /etc/nginx/sites-available/x-trend-webapp
#   sudo ln -s /etc/nginx/sites-available/x-trend-webapp /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 443 ssl http2;
    server_name trend.example.com;          # ← 换成你的域名

    ssl_certificate     /etc/letsencrypt/live/trend.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/trend.example.com/privkey.pem;

    location / {
        proxy_pass         http://127.0.0.1:8088;   # 对应 WEBAPP_HOST/WEBAPP_PORT
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}

# HTTP -> HTTPS 跳转
server {
    listen 80;
    server_name trend.example.com;           # ← 换成你的域名
    return 301 https://$host$request_uri;
}
