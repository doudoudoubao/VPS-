[Unit]
Description=X Trending Telegram Mini App 后端
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/VPS-
EnvironmentFile=/opt/VPS-/config.env
ExecStart=/usr/bin/python3 /opt/VPS-/webapp_server.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
