# ===== 复制为 config.env 并填入你自己的值 =====
# 使用方式: export $(grep -v '^#' config.env | xargs)   或   配合 --env-file (docker)

# ---------- RapidAPI (X/Twitter 数据源) ----------
# 1. 注册 https://rapidapi.com
# 2. 订阅一个带 "trends" 接口的 Twitter API (默认用 twitter154, 有免费额度)
#    https://rapidapi.com/omarmhaimdat/api/twitter154
RAPIDAPI_KEY=你的_rapidapi_key

# 一般不用改; 如果你订阅的是别的提供方, 按其文档修改下面三项
RAPIDAPI_HOST=twitter154.p.rapidapi.com
RAPIDAPI_TRENDS_PATH=/trends/
RAPIDAPI_WOEID_PARAM=woeid

# ---------- 地区轮播 ----------
# 多个地区用逗号分隔, 会按顺序轮流推送 (每次推一个)
# WOEID: 1=全球  23424977=美国  23424856=日本  23424975=英国  23424819=韩国
TREND_WOEID=1,23424977,23424856
# 地区显示名, 与上面 WOEID 一一对应 (缺省则显示 "WOEID xxx")
TREND_REGION_LABEL=全球,美国,日本
# on=每次轮流推一个地区(轮播);  off=每次把所有地区都推一遍
TREND_ROTATE=on

# ---------- Telegram (支持私聊 / 群 / 频道, 可多个) ----------
# 1. 找 @BotFather 创建 bot, 拿到 token
# 2a. 私聊/群: 给 bot 发消息, 再用 @userinfobot 取 chat_id (群是负数)
# 2b. 频道: 把 bot 设为频道管理员, chat_id 直接填 @频道用户名 (或 -100 开头的数字 id)
# 多个目标用逗号分隔, 会同时推送到所有目标
TELEGRAM_BOT_TOKEN=123456:ABC-你的bot token
TELEGRAM_CHAT_ID=你的chat_id,@你的频道用户名

# ---------- 定时静音 ----------
# 在该时段内不推送 (本地时间, 24 小时制); 支持跨午夜, 如 23:00-07:00
# 留空表示全天推送
QUIET_HOURS=23:00-07:00

# ---------- 其它推送行为 ----------
TREND_TOP_N=15          # 最多推送前 N 条
TREND_MIN_VOLUME=0      # 只推送讨论量 >= 该值的趋势 (0=不过滤)
# STATE_FILE=.trend_state.json   # 去重/轮播状态文件位置
# HTTP_TIMEOUT=20

# ---------- Telegram Mini App (可视化界面, 可选) ----------
# 运行 webapp_server.py 即可在 Telegram 里打开一个小程序:
# 浏览趋势 / 在线改设置 / 一键立即推送。设置会写入 .webapp_settings.json,
# cron / 常驻 bot 下次运行自动生效。
WEBAPP_HOST=127.0.0.1   # 监听地址 (建议放 nginx 后面, 仅本机可达)
WEBAPP_PORT=8088        # 监听端口
WEBAPP_AUTH=on          # on=校验 Telegram initData(必开); off 仅供本地调试
# WEBAPP_ALLOWED_USER_IDS=     # 逗号分隔的 Telegram user id 白名单 (留空=不限制)
# WEBAPP_INITDATA_MAX_AGE=86400  # initData 有效期(秒), 防重放; 0=不校验时间
# Mini App 的公网 https 地址, 用于 `python webapp_server.py --set-menu`
# 把 bot 菜单按钮设为打开本小程序
# WEBAPP_PUBLIC_URL=https://trend.example.com
